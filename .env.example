# TitanFit — Plantilla de Variables de Entorno
# Copia este archivo como .env y rellena tus valores reales.
# El archivo .env NUNCA debe subirse a GitHub.

# Supabase
EXPO_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key-aqui

# Gemini AI (para generación de planes nutricionales)
EXPO_PUBLIC_GEMINI_API_KEY=tu-gemini-api-key-aqui
EXPO_PUBLIC_GEMINI_MODEL=gemini-2.5-flash
